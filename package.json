{
  "name": "canvas-text-mirror",
  "version": "0.1.0",
  "description": "Pixel-perfect DOM text → Canvas 2D mirror. Clone any HTML subtree onto a canvas with exact fonts, colors, line breaks, and letter-spacing.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "coverage": "vitest run --coverage"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue.js",
      "types": "./dist/vue.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./svelte": {
      "import": "./dist/svelte.js",
      "types": "./dist/svelte.d.ts"
    },
    "./angular": {
      "import": "./dist/angular.js",
      "types": "./dist/angular.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "canvas",
    "text",
    "dom",
    "mirror",
    "pixel-perfect",
    "typography",
    "particles",
    "effects"
  ],
  "author": "Pery Mimon",
  "license": "MIT",
  "peerDependencies": {
    "@angular/core": ">=17",
    "react": ">=18",
    "svelte": ">=4",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/core": "^21.2.8",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "typescript": "^5.0.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue": "^3.5.32"
  }
}
